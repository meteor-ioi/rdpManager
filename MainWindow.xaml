<Window x:Class="rdpManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LocalRDP - 本地多用户虚拟桌面" Height="820" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="#F4F4F5" BorderBrush="#E4E4E7" BorderThickness="0">

    <Window.Resources>
        <!-- 基础全局样式 -->
        <FontFamily x:Key="MainFont">Microsoft YaHei, Segoe UI, Arial</FontFamily>

        <!-- 扁平卡片阴影 -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E4E4E7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- 极简 Expander 样式 -->
        <Style x:Key="ModernExpander" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <DockPanel>
                                <ToggleButton x:Name="HeaderSite"
                                              DockPanel.Dock="Top"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Padding="0,0,0,8"
                                              HorizontalContentAlignment="Stretch"
                                              Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <ContentPresenter Content="{TemplateBinding Content}" 
                                                                      ContentTemplate="{TemplateBinding ContentTemplate}" 
                                                                      HorizontalAlignment="Stretch"
                                                                      VerticalAlignment="Center"/>
                                                    
                                                    <!-- 精致的无圆圈三角折叠箭头 -->
                                                    <Path x:Name="ArrowPath"
                                                          Grid.Column="1"
                                                          Data="M 0 0 L 4 4 L 8 0"
                                                          Stroke="#71717A"
                                                          StrokeThickness="1.5"
                                                          HorizontalAlignment="Right"
                                                          VerticalAlignment="Center"
                                                          Margin="10,0,0,0"
                                                          RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="0"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=Expander}}" Value="True">
                                                    <Setter TargetName="ArrowPath" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="180"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter TargetName="ArrowPath" Property="Stroke" Value="#18181B"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ArrowPath" Property="Stroke" Value="#18181B"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                
                                <ContentPresenter x:Name="ExpandSite"
                                                  DockPanel.Dock="Bottom"
                                                  Visibility="Collapsed"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Margin="{TemplateBinding Padding}"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 扁平黑色大按钮（类 Tailwind text-white bg-black） -->
        <Style x:Key="PrimaryBlackButton" TargetType="Button">
            <Setter Property="Background" Value="#09090B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="BtnBorder">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#27272A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#E4E4E7"/>
                                <Setter Property="Foreground" Value="#A1A1AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 扁平白色边框按钮 (类 Tailwind border-zinc-200) -->
        <Style x:Key="SecondaryBorderButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E4E4E7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" x:Name="BtnBorder">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#F4F4F5"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#D4D4D8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#F4F4F5"/>
                                <Setter Property="Foreground" Value="#A1A1AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 扁平白色边框警告按钮 (类 Tailwind text-rose-500) -->
        <Style x:Key="DangerBorderButton" TargetType="Button" BasedOn="{StaticResource SecondaryBorderButton}">
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="BorderBrush" Value="#FCA5A5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" x:Name="BtnBorder">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#FEF2F2"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#E4E4E7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6,8,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#09090B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 密码框样式 -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="BorderBrush" Value="#E4E4E7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6,8,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#09090B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉选择框样式 -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="#E4E4E7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,4,6,4"/>
        </Style>

        <!-- 复选框样式 -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部 Header -->
            <RowDefinition Height="Auto"/>
            <!-- 可滚动的内容区域 -->
            <RowDefinition Height="*"/>
            <!-- 底部操作栏 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ======================= 顶部 Header ======================= -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E4E4E7" BorderThickness="0,0,0,1" Padding="16,14,16,12">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 标题 & 徽章 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="LocalRDP" FontSize="16" FontFamily="{StaticResource MainFont}" FontWeight="Bold" Foreground="#09090B" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 状态标签区 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- 提权状态 -->
                        <Border x:Name="AdminTag" Background="#FEF2F2" CornerRadius="4" Padding="6,2,6,2">
                            <TextBlock x:Name="AdminTagTxt" Text="受限运行" FontSize="10" FontWeight="SemiBold" Foreground="#EF4444"/>
                        </Border>
                        <!-- RDP状态 -->
                        <Border x:Name="RdpTag" Background="#F4F4F5" CornerRadius="4" Padding="6,2,6,2" Margin="6,0,0,0">
                            <TextBlock x:Name="RdpTagTxt" Text="RDP关" FontSize="10" FontWeight="SemiBold" Foreground="#71717A"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ======================= 中部滚动卡片区 ======================= -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14,14,14,0">
            <StackPanel>
                
                <!-- 权限警告横幅 (如果没管理员权限就显示) -->
                <Border x:Name="PrivilegeWarningAlert" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,14" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⚠️ 权限不足 (受限运行)" FontWeight="Bold" Foreground="#991B1B" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock Text="本程序未以管理员身份运行。请关闭并重新右键“以管理员身份运行”打开本程序，否则补丁部署与账号管理功能将无法生效。" Foreground="#B91C1C" FontSize="11" TextWrapping="Wrap" LineHeight="16"/>
                    </StackPanel>
                </Border>

                <!-- 1. 并发补丁管理 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <Expander x:Name="ExpanderPatchManager" Style="{StaticResource ModernExpander}" IsExpanded="True">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛡️" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="并发补丁管理" FontSize="12" FontWeight="Bold" Foreground="#3F3F46"/>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Margin="0,12,0,0">
                            <!-- TermWrap 状态 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="并发组件 (TermWrap)" FontSize="12" Foreground="#71717A" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TermWrapStatusLabel" Grid.Column="1" Text="未安装" FontSize="12" FontWeight="Bold" Foreground="#EF4444" VerticalAlignment="Center"/>
                            </Grid>
                            <!-- EndpWrap 状态 -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="音频保活 (EndpWrap)" FontSize="12" Foreground="#71717A" VerticalAlignment="Center"/>
                                <TextBlock x:Name="EndpWrapStatusLabel" Grid.Column="1" Text="未安装" FontSize="12" FontWeight="Bold" Foreground="#EF4444" VerticalAlignment="Center"/>
                            </Grid>
                            <!-- 补丁操作按钮 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnInstallPatch" Grid.Column="0" Content="安装补丁" Style="{StaticResource PrimaryBlackButton}" Height="32" Click="BtnInstallPatch_Click"/>
                                <Button x:Name="BtnUninstallPatch" Grid.Column="2" Content="还原默认" Style="{StaticResource DangerBorderButton}" Height="32" Click="BtnUninstallPatch_Click"/>
                            </Grid>
                        </StackPanel>
                    </Expander>
                </Border>

                <!-- 2. 系统账号设置 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <Expander Style="{StaticResource ModernExpander}" IsExpanded="True">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👤" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="系统账号设置" FontSize="12" FontWeight="Bold" Foreground="#3F3F46"/>
                                </StackPanel>
                                <Button x:Name="BtnNewUser" Grid.Column="1" Content="+" Foreground="#3F3F46" Background="Transparent" BorderThickness="0" FontSize="16" FontWeight="Bold" Cursor="Hand" Click="BtnNewUser_Click" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Expander.Header>
                        <StackPanel Margin="0,12,0,0">
                            <!-- 账号下拉及删除 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="ComboAccounts" Grid.Column="0" Style="{StaticResource ModernComboBox}" SelectionChanged="ComboAccounts_SelectionChanged"/>
                                <Button x:Name="BtnDeleteAccount" Grid.Column="2" Content="🗑️" Width="30" Height="30" Style="{StaticResource SecondaryBorderButton}" ToolTip="删除选中用户" Click="BtnDeleteAccount_Click"/>
                            </Grid>
                            <!-- 密码输入与眼睛显隐 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- 密码框(密文) & 文本框(明文) -->
                                <PasswordBox x:Name="AccountPasswordBox" Style="{StaticResource ModernPasswordBox}" Height="30" VerticalContentAlignment="Center" Margin="0" Grid.Column="0" PasswordChanged="AccountPasswordBox_PasswordChanged"/>
                                <TextBox x:Name="AccountPasswordTxt" Style="{StaticResource ModernTextBox}" Height="30" VerticalContentAlignment="Center" Margin="0" Grid.Column="0" Visibility="Collapsed" TextChanged="AccountPasswordTxt_TextChanged"/>
                                
                                <Button x:Name="BtnShowHidePassword" Grid.Column="1" Content="👁️" Width="30" Height="30" Style="{StaticResource SecondaryBorderButton}" Margin="4,0,0,0" Click="BtnShowHidePassword_Click"/>
                            </Grid>
                        </StackPanel>
                    </Expander>
                </Border>

                <!-- 3. 重定向及保活 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <Expander Style="{StaticResource ModernExpander}" IsExpanded="True">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙️" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="重定向及保活" FontSize="12" FontWeight="Bold" Foreground="#3F3F46"/>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Margin="0,12,0,0">
                            <!-- 分辨率与缩放 -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="分辨率" FontSize="11" Foreground="#71717A" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="ComboResolution" Style="{StaticResource ModernComboBox}">
                                        <ComboBoxItem Content="自适应窗口" Tag="0x0"/>
                                        <ComboBoxItem Content="1920×1080" Tag="1920x1080"/>
                                        <ComboBoxItem Content="2560×1440" Tag="2560x1440"/>
                                        <ComboBoxItem Content="3840×2160" Tag="3840x2160"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="缩放" FontSize="11" Foreground="#71717A" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="ComboScale" Style="{StaticResource ModernComboBox}">
                                        <ComboBoxItem Content="100%" Tag="100"/>
                                        <ComboBoxItem Content="125%" Tag="125"/>
                                        <ComboBoxItem Content="150%" Tag="150"/>
                                        <ComboBoxItem Content="175%" Tag="175"/>
                                        <ComboBoxItem Content="200%" Tag="200"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- 外设重定向 -->
                            <Border Background="#FAFAFA" BorderBrush="#F4F4F5" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="外设重定向" FontSize="11" FontWeight="Bold" Foreground="#71717A" Margin="0,0,0,8"/>
                                    <UniformGrid Columns="2">
                                        <CheckBox x:Name="ChkClipboard" Content="同步剪贴板" Style="{StaticResource ModernCheckBox}" IsChecked="True"/>
                                        <CheckBox x:Name="ChkAudio" Content="重定向音频" Style="{StaticResource ModernCheckBox}" IsChecked="True"/>
                                        <CheckBox x:Name="ChkMicrophone" Content="重定向麦克风" Style="{StaticResource ModernCheckBox}" IsChecked="False"/>
                                        <CheckBox x:Name="ChkDrives" Content="挂载本地磁盘" Style="{StaticResource ModernCheckBox}" IsChecked="False"/>
                                        <CheckBox x:Name="ChkPrinters" Content="共享打印机" Style="{StaticResource ModernCheckBox}" IsChecked="False"/>
                                        <CheckBox x:Name="ChkSmartSizing" Content="自适应窗口" Style="{StaticResource ModernCheckBox}" IsChecked="True"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <!-- 远程环境保活锁定 -->
                            <Border Background="#FAFAFA" BorderBrush="#F4F4F5" BorderThickness="1" CornerRadius="4" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="远程环境保活锁定" FontSize="11" FontWeight="Bold" Foreground="#71717A" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="ChkAutoReconnect" Content="断开时自动尝试重新连接" Style="{StaticResource ModernCheckBox}" IsChecked="True"/>
                                    <CheckBox x:Name="ChkKeepResolution" Content="锁定强制恢复显卡分辨率" Style="{StaticResource ModernCheckBox}" IsChecked="True"/>
                                    <CheckBox x:Name="ChkPreventSleep" Content="阻止主机睡眠和锁屏" Style="{StaticResource ModernCheckBox}" IsChecked="True"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Expander>
                </Border>

                <!-- 4. 活跃会话管理 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <Expander Style="{StaticResource ModernExpander}" IsExpanded="True">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔄" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="活跃会话管理" FontSize="12" FontWeight="Bold" Foreground="#3F3F46"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#E4E4E7" CornerRadius="8" Padding="6,1,6,1" VerticalAlignment="Center" Margin="0,0,4,0">
                                    <TextBlock x:Name="SessionCountBadge" Text="0" FontSize="10" FontWeight="Bold" Foreground="#3F3F46"/>
                                </Border>
                            </Grid>
                        </Expander.Header>
                        <StackPanel Margin="0,12,0,0">
                            <!-- 无活跃会话提示 -->
                            <TextBlock x:Name="NoSessionsPlaceholder" Text="当前暂无活跃回环会话" FontSize="11" Foreground="#A1A1AA" HorizontalAlignment="Center" Margin="0,10" Visibility="Visible"/>
                            
                            <!-- 会话列表 -->
                            <ListBox x:Name="ListSessions" BorderThickness="0" Background="Transparent" d:ItemsSource="{d:SampleData ItemCount=2}" Margin="0,0,0,4" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0,4"/>
                                        <Setter Property="Focusable" Value="False"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F4F4F5" BorderThickness="0,0,0,1" Padding="0,6,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- 会话信息 -->
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="会话 " FontSize="12" FontWeight="Bold" Foreground="#18181B"/>
                                                        <TextBlock Text="{Binding SessionId}" FontSize="12" FontWeight="Bold" Foreground="#18181B"/>
                                                        <TextBlock Text=" : " FontSize="12" FontWeight="Bold" Foreground="#18181B"/>
                                                        <TextBlock Text="{Binding Username}" FontSize="12" FontWeight="Bold" Foreground="#18181B"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding StateText}" FontSize="11" Foreground="#10B981" Margin="0,0,8,0"/>
                                                        <TextBlock Text="运行时间: " FontSize="11" Foreground="#71717A"/>
                                                        <TextBlock Text="{Binding DurationText}" FontSize="11" Foreground="#71717A"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <!-- 会话操作 -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="打开会话" Style="{StaticResource SecondaryBorderButton}" Width="52" Click="BtnOpenSession_Click" Tag="{Binding Username}"/>
                                                    <Button Content="保活断开" Style="{StaticResource SecondaryBorderButton}" Width="52" Click="BtnDisconnectSession_Click" Tag="{Binding SessionId}" Margin="4,0,0,0"/>
                                                    <Button Content="彻底退出" Style="{StaticResource DangerBorderButton}" Width="52" Click="BtnLogoffSession_Click" Tag="{Binding SessionId}" Margin="4,0,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Expander>
                </Border>

                <!-- 5. 物理运行日志 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <Expander Style="{StaticResource ModernExpander}" IsExpanded="False">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📝" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="物理运行日志" FontSize="12" FontWeight="Bold" Foreground="#3F3F46"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="📤" ToolTip="导出日志" Foreground="#3F3F46" Background="Transparent" BorderThickness="0" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="BtnExportLog_Click" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Expander.Header>
                        <TextBox x:Name="TxtLogOutput" Height="140" Style="{StaticResource ModernTextBox}" 
                                 Background="#18181B" Foreground="#A1A1AA" Margin="0,12,0,0"
                                 VerticalScrollBarVisibility="Auto" AcceptsReturn="True" IsReadOnly="True" 
                                 TextWrapping="Wrap" FontFamily="Consolas, Courier New" FontSize="11"/>
                    </Expander>
                </Border>
                
                <!-- 底部撑开间距 -->
                <Border Height="8"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ======================= 底部操作栏 ======================= -->
        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E4E4E7" BorderThickness="0,1,0,0" Padding="14,12,14,14">
            <Button x:Name="BtnConnectVirtualDesktop" Content="🔌 连接虚拟桌面" Style="{StaticResource PrimaryBlackButton}" Height="40" FontSize="14" Click="BtnConnectVirtualDesktop_Click"/>
        </Border>

        <!-- ======================= 全局新建用户模态框 ======================= -->
        <Grid x:Name="NewUserModal" Grid.RowSpan="3" Background="#80000000" Visibility="Collapsed">
            <Border Width="340" HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Background="#FFFFFF" BorderBrush="#E4E4E7" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="新建本地隔离账户" FontSize="14" FontWeight="Bold" Foreground="#09090B" Margin="0,0,0,16"/>
                    
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="账号名称" FontSize="11" Foreground="#71717A" Margin="0,0,0,4"/>
                        <TextBox x:Name="NewUserUsernameTxt" Height="30" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,0,16">
                        <Grid>
                            <TextBlock Text="连接密码" FontSize="11" Foreground="#71717A" Margin="0,0,0,4"/>
                            <Button Content="随机强密码" Foreground="#5985E1" Background="Transparent" BorderThickness="0" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" Click="BtnGeneratePassword_Click"/>
                        </Grid>
                        <TextBox x:Name="NewUserPasswordTxt" Height="30" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                    
                    <!-- 正在创建时的提示面板 -->
                    <StackPanel x:Name="NewUserLoadingPanel" Visibility="Collapsed" Margin="0,0,0,16">
                        <ProgressBar IsIndeterminate="True" Height="4" Background="#E4E4E7" Foreground="#09090B" BorderThickness="0"/>
                        <TextBlock Text="正在配置组策略和分配隔离权限，请稍候..." FontSize="11" Foreground="#71717A" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnCancelNewUser" Content="取消" Style="{StaticResource SecondaryBorderButton}" Height="32" Click="BtnCancelNewUser_Click"/>
                        <Button x:Name="BtnConfirmCreateUser" Content="确认创建" Grid.Column="2" Style="{StaticResource PrimaryBlackButton}" Height="32" Click="BtnConfirmCreateUser_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>