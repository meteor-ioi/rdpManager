<Window x:Class="rdpManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LocalRDP - 多用户虚拟桌面" Height="820" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource WindowBackgroundBrush}" BorderThickness="0">

    <Window.Resources>
        <!-- 基础全局样式 -->
        <FontFamily x:Key="MainFont">Microsoft YaHei, Segoe UI, Arial</FontFamily>

        <!-- 扁平卡片阴影 -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- 极简 Expander 样式 -->
        <Style x:Key="ModernExpander" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <DockPanel>
                            <ToggleButton x:Name="HeaderSite" ContentTemplate="{TemplateBinding HeaderTemplate}" ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}" Content="{TemplateBinding Header}" DockPanel.Dock="Top" IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Margin="0" MinHeight="0" MinWidth="0" Padding="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Padding="0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 0 8 Z" Fill="{DynamicResource IconFillBrush}" Margin="0,0,8,0" RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                                <ContentPresenter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="90"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource IconHoverFillBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite" DockPanel.Dock="Bottom" Focusable="false" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="{TemplateBinding Padding}" Visibility="Collapsed" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </DockPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="true">
                                <Setter Property="Visibility" TargetName="ExpandSite" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 扁平黑色大按钮（类 Tailwind text-white bg-black） -->
        <Style x:Key="PrimaryBlackButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBtnBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBtnForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="BtnBorder">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource PrimaryBtnHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource PrimaryBtnDisabledBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBtnDisabledTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 扁平白色边框按钮 (类 Tailwind border-zinc-200) -->
        <Style x:Key="SecondaryBorderButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryBtnBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryBtnForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SecondaryBtnBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" x:Name="BtnBorder">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource SecondaryBtnHoverBgBrush}"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{DynamicResource SecondaryBtnHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource SecondaryBtnHoverBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBtnDisabledTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 扁平白色边框警告按钮 (类 Tailwind text-rose-500) -->
        <Style x:Key="DangerBorderButton" TargetType="Button" BasedOn="{StaticResource SecondaryBorderButton}">
            <Setter Property="Foreground" Value="{DynamicResource DangerBtnForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBtnBorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" x:Name="BtnBorder">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource DangerBtnHoverBgBrush}"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{DynamicResource DangerBtnHoverBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6,8,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 密码框样式 -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6,8,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉选择框样式 (带圆角和悬停/打开状态交互) -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4,8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- 外部圆角边框 -->
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- 选中的文本内容展示 -->
                                    <ContentPresenter x:Name="contentPresenter" 
                                                      Content="{TemplateBinding SelectionBoxItem}" 
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" 
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                                      Margin="{TemplateBinding Padding}" 
                                                      IsHitTestVisible="False"/>
                                    
                                    <!-- 右侧下拉三角按钮 -->
                                    <ToggleButton x:Name="toggleButton" 
                                                  Grid.Column="1" 
                                                  Background="Transparent" 
                                                  BorderThickness="0" 
                                                  Margin="0"
                                                  Width="24"
                                                  Cursor="Hand"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <Path x:Name="Arrow" 
                                                          HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center" 
                                                          Data="M 0 0 L 3.5 3.5 L 7 0 Z" 
                                                          Fill="{DynamicResource IconFillBrush}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource IconHoverFillBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            
                            <!-- 下拉菜单弹出窗体 -->
                            <Popup x:Name="popup" 
                                   AllowsTransparency="True" 
                                   IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   Placement="Bottom" 
                                   PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder" 
                                        Background="#FFFFFF" 
                                        BorderBrush="#E4E4E7" 
                                        BorderThickness="1" 
                                        CornerRadius="6" 
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}" 
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" 
                                        Margin="0,2,0,0">
                                    <ScrollViewer x:Name="dropDownScrollViewer" SnapsToDevicePixels="True">
                                        <Grid x:Name="grid" RenderOptions.ClearTypeHint="Enabled">
                                            <Canvas x:Name="canvas" HorizontalAlignment="Left" Height="0" VerticalAlignment="Top" Width="0">
                                                <Rectangle x:Name="opaqueRect" Fill="{Binding Background, ElementName=dropDownBorder}" Height="{Binding ActualHeight, ElementName=dropDownBorder}" Width="{Binding ActualWidth, ElementName=dropDownBorder}"/>
                                            </Canvas>
                                            <ItemsPresenter x:Name="itemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#D4D4D8"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBtnDisabledTextBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="#F4F4F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 复选框样式 -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 现代极简细 ScrollBar 的 RepeatButton 透明模板 -->
        <ControlTemplate x:Key="ScrollBarPageButtonTemplate" TargetType="RepeatButton">
            <Border Background="Transparent" />
        </ControlTemplate>

        <!-- 默认 ScrollBar 样式（让整个应用中所有的滚动条全部变成现代化细条） -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent" BorderThickness="0" Template="{StaticResource ScrollBarPageButtonTemplate}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent" BorderThickness="0" Template="{StaticResource ScrollBarPageButtonTemplate}"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="{DynamicResource ScrollbarThumbBrush}" BorderThickness="0">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="3" Margin="1,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger SourceName="Thumb" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollbarThumbHoverBrush}"/>
                            </Trigger>
                            <Trigger SourceName="Thumb" Property="IsDragging" Value="True">
                                <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollbarThumbDraggingBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollbarThumbHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid x:Name="Bg" SnapsToDevicePixels="True">
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand" Background="Transparent" BorderThickness="0" Template="{StaticResource ScrollBarPageButtonTemplate}"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand" Background="Transparent" BorderThickness="0" Template="{StaticResource ScrollBarPageButtonTemplate}"/>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb x:Name="Thumb" Background="{DynamicResource ScrollbarThumbBrush}" BorderThickness="0">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Margin="0,1"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger SourceName="Thumb" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollbarThumbHoverBrush}"/>
                                    </Trigger>
                                    <Trigger SourceName="Thumb" Property="IsDragging" Value="True">
                                        <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollbarThumbDraggingBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollbarThumbHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部 Header -->
            <RowDefinition Height="Auto"/>
            <!-- 可滚动的内容区域 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ======================= 顶部 Header ======================= -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" BorderBrush="{DynamicResource HeaderBorderBrush}" BorderThickness="0,0,0,1" Padding="16,14,16,12">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 标题 & 徽章 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="LocalRDP" FontSize="16" FontFamily="{StaticResource MainFont}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 状态标签区 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- 主题切换 -->
                        <ComboBox x:Name="ComboTheme" Style="{StaticResource ModernComboBox}" Width="85" Height="24" FontSize="11" Margin="0,0,8,0" Padding="6,0" SelectionChanged="ComboTheme_SelectionChanged">
                            <ComboBoxItem Content="跟随系统" Tag="System"/>
                            <ComboBoxItem Content="白 天" Tag="Light"/>
                            <ComboBoxItem Content="黑 夜" Tag="Dark"/>
                        </ComboBox>
                        
                        <!-- 提权状态 -->
                        <Border x:Name="AdminTag" Background="{DynamicResource BadgeDangerBgBrush}" CornerRadius="4" Padding="6,2,6,2">
                            <TextBlock x:Name="AdminTagTxt" Text="受限运行" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource BadgeDangerTextBrush}"/>
                        </Border>
                        <!-- RDP状态 -->
                        <Border x:Name="RdpTag" Background="{DynamicResource BadgeDisabledBgBrush}" CornerRadius="4" Padding="6,2,6,2" Margin="6,0,0,0">
                            <TextBlock x:Name="RdpTagTxt" Text="RDP关" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ======================= 中部滚动卡片区 ======================= -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14,14,14,0">
            <StackPanel>
                
                <!-- 权限警告横幅 (如果没管理员权限就显示) -->
                <Border x:Name="PrivilegeWarningAlert" Background="{DynamicResource AlertErrorBgBrush}" BorderBrush="{DynamicResource AlertErrorBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,14" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⚠️ 权限不足 (受限运行)" FontWeight="Bold" Foreground="{DynamicResource AlertErrorTitleBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock Text="本程序未以管理员身份运行。请关闭并重新右键“以管理员身份运行”打开本程序，否则补丁部署与账号管理功能将无法生效。" Foreground="{DynamicResource AlertErrorTextBrush}" FontSize="11" TextWrapping="Wrap" LineHeight="16"/>
                    </StackPanel>
                </Border>

                <!-- 1. 并发补丁管理 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <Expander x:Name="ExpanderPatchManager" Style="{StaticResource ModernExpander}" IsExpanded="True">
                        <Expander.Header>
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="38"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                    <TextBlock Text="🛡️" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="并发补丁管理" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextHeadingBrush}"/>
                                </StackPanel>
                                <TextBlock x:Name="PatchSuccessIcon" Grid.Column="1" Text="✅" FontSize="12" Margin="0,0,8,0" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Expander.Header>
                        <StackPanel Margin="0,12,0,0">
                            <!-- RDP未开启警告横幅 -->
                            <Border x:Name="RdpDisabledWarningAlert" Background="{DynamicResource AlertWarningBgBrush}" BorderBrush="{DynamicResource AlertWarningBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,10" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="⚠️ 系统远程桌面功能尚未开启！" FontWeight="Bold" Foreground="{DynamicResource AlertWarningTitleBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBlock Text="请前往“设置” -> “系统” -> “远程桌面”启用后，再安装补丁。" Foreground="{DynamicResource AlertWarningTextBrush}" FontSize="11" TextWrapping="Wrap" LineHeight="16"/>
                                </StackPanel>
                            </Border>
                            <!-- TermWrap 状态 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="并发组件 (TermWrap)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TermWrapStatusLabel" Grid.Column="1" Text="未安装" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BadgeDangerTextBrush}" VerticalAlignment="Center"/>
                            </Grid>
                            <!-- RdpWrap 状态 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="降级组件 (RdpWrap)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="RdpWrapStatusLabel" Grid.Column="1" Text="未安装" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BadgeDangerTextBrush}" VerticalAlignment="Center"/>
                            </Grid>
                            <!-- EndpWrap 状态 -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="音频保活 (EndpWrap)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="EndpWrapStatusLabel" Grid.Column="1" Text="未安装" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BadgeDangerTextBrush}" VerticalAlignment="Center"/>
                            </Grid>
                            <!-- 补丁操作按钮 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnInstallPatch" Grid.Column="0" Content="安装补丁" Style="{StaticResource PrimaryBlackButton}" Height="32" Click="BtnInstallPatch_Click"/>
                                <Button x:Name="BtnUninstallPatch" Grid.Column="2" Content="还原默认" Style="{StaticResource DangerBorderButton}" Height="32" Click="BtnUninstallPatch_Click"/>
                            </Grid>
                        </StackPanel>
                    </Expander>
                </Border>

                <!-- 2. 连接设置 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <!-- 卡片头部 -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="👤" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="账号连接设置" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextHeadingBrush}"/>
                            </StackPanel>
                            <Button x:Name="BtnNewUser" Grid.Column="1" Content="+" Foreground="{DynamicResource TextHeadingBrush}" Background="Transparent" BorderThickness="0" FontSize="16" FontWeight="Bold" Cursor="Hand" Click="BtnNewUser_Click" Width="30" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- ① 账号选择区（始终可见） -->
                        <StackPanel>
                            <!-- 账号下拉及删除 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="ComboAccounts" Grid.Column="0" Style="{StaticResource ModernComboBox}" SelectionChanged="ComboAccounts_SelectionChanged"/>
                                <Button x:Name="BtnDeleteAccount" Grid.Column="2" Content="🗑️" Width="30" Height="30" Style="{StaticResource SecondaryBorderButton}" ToolTip="删除选中用户" Click="BtnDeleteAccount_Click"/>
                            </Grid>
                            <!-- 密码输入与眼睛显隐 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <PasswordBox x:Name="AccountPasswordBox" Style="{StaticResource ModernPasswordBox}" Height="30" VerticalContentAlignment="Center" Margin="0" Grid.Column="0" PasswordChanged="AccountPasswordBox_PasswordChanged"/>
                                <TextBox x:Name="AccountPasswordTxt" Style="{StaticResource ModernTextBox}" Height="30" VerticalContentAlignment="Center" Margin="0" Grid.Column="0" Visibility="Collapsed" TextChanged="AccountPasswordTxt_TextChanged"/>
                                
                                <Button x:Name="BtnShowHidePassword" Grid.Column="2" Content="👁️" Width="30" Height="30" Style="{StaticResource SecondaryBorderButton}" Margin="0" Click="BtnShowHidePassword_Click"/>
                            </Grid>
                        </StackPanel>

                        <!-- ② 折叠区（点击箭头展开高级选项） -->
                        <Grid Margin="0,4,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Separator Grid.Column="0" Background="{DynamicResource BadgeNeutralBgBrush}" VerticalAlignment="Center"/>
                            <Button x:Name="BtnToggleAdvancedSettings" Grid.Column="1" Style="{StaticResource SecondaryBorderButton}" 
                                    Height="24" Padding="8,2" BorderThickness="0" Background="Transparent" Click="BtnToggleAdvancedSettings_Click" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtAdvancedSettingsArrow" Text="▼" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="高级功能" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                            <Separator Grid.Column="2" Background="{DynamicResource BadgeNeutralBgBrush}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- ③ 高级选项区（默认折叠） -->
                        <StackPanel x:Name="PanelAdvancedSettings" Visibility="Collapsed" Margin="0,0,0,12">
                            <!-- 分辨率与缩放 -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="分辨率" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="ComboResolution" Style="{StaticResource ModernComboBox}">
                                        <ComboBoxItem Content="自适应窗口" Tag="0x0"/>
                                        <ComboBoxItem Content="1920×1080" Tag="1920x1080"/>
                                        <ComboBoxItem Content="2560×1440" Tag="2560x1440"/>
                                        <ComboBoxItem Content="3840×2160" Tag="3840x2160"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="缩放" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="ComboScale" Style="{StaticResource ModernComboBox}">
                                        <ComboBoxItem Content="100%" Tag="100"/>
                                        <ComboBoxItem Content="125%" Tag="125"/>
                                        <ComboBoxItem Content="150%" Tag="150"/>
                                        <ComboBoxItem Content="175%" Tag="175"/>
                                        <ComboBoxItem Content="200%" Tag="200"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- 外设重定向 -->
                            <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="外设重定向" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                    <UniformGrid Columns="2">
                                        <CheckBox x:Name="ChkClipboard" Content="同步剪贴板" Style="{StaticResource ModernCheckBox}" IsChecked="True"/>
                                        <CheckBox x:Name="ChkAudio" Content="重定向音频" Style="{StaticResource ModernCheckBox}" IsChecked="True"/>
                                        <CheckBox x:Name="ChkMicrophone" Content="重定向麦克风" Style="{StaticResource ModernCheckBox}" IsChecked="False"/>
                                        <CheckBox x:Name="ChkDrives" Content="挂载本地磁盘" Style="{StaticResource ModernCheckBox}" IsChecked="False"/>
                                        <CheckBox x:Name="ChkPrinters" Content="共享打印机" Style="{StaticResource ModernCheckBox}" IsChecked="False"/>
                                        <CheckBox x:Name="ChkSmartSizing" Content="自适应窗口" Style="{StaticResource ModernCheckBox}" IsChecked="True"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <!-- 远程环境保活锁定 -->
                            <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="4" Padding="10" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="远程环境保活锁定" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="ChkKeepResolution" Content="锁定强制恢复显卡分辨率" Style="{StaticResource ModernCheckBox}" IsChecked="True"/>
                                    <CheckBox x:Name="ChkPreventSleep" Content="阻止主机睡眠和锁屏" Style="{StaticResource ModernCheckBox}" IsChecked="True"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ④ 连接虚拟桌面按钮 -->
                        <Button x:Name="BtnConnectVirtualDesktop" Content="🔌 连接虚拟桌面" Style="{StaticResource PrimaryBlackButton}" Height="38" FontSize="13" Click="BtnConnectVirtualDesktop_Click"/>
                    </StackPanel>
                </Border>

                <!-- 4. 活跃会话管理 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <Expander Style="{StaticResource ModernExpander}" IsExpanded="True">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                    <TextBlock Text="🔄" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="活跃会话管理" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextHeadingBrush}"/>
                                </StackPanel>
                                <Button x:Name="BtnCleanZombieSessions" Grid.Column="1" Content="🧹" ToolTip="清理所有断开会话" Width="26" Height="22" Style="{StaticResource SecondaryBorderButton}" Margin="0,0,6,0" Padding="0" Click="BtnCleanZombieSessions_Click"/>
                                <Border Grid.Column="2" Background="{DynamicResource BadgeNeutralBgBrush}" CornerRadius="8" Padding="6,1,6,1" VerticalAlignment="Center">
                                    <TextBlock x:Name="SessionCountBadge" Text="0" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextHeadingBrush}"/>
                                </Border>
                            </Grid>
                        </Expander.Header>
                        <StackPanel Margin="0,12,0,0">
                            <!-- 无活跃会话提示 -->
                            <TextBlock x:Name="NoSessionsPlaceholder" Text="当前暂无活跃回环会话" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,10" Visibility="Visible"/>
                            
                            <!-- 会话列表 -->
                            <ListBox x:Name="ListSessions" BorderThickness="0" Background="Transparent" d:ItemsSource="{d:SampleData ItemCount=2}" Margin="0,0,0,4" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0,4"/>
                                        <Setter Property="Focusable" Value="False"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F4F4F5" BorderThickness="0,0,0,1" Padding="0,6,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- 会话信息 -->
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="会话 " FontSize="12" FontWeight="Bold" Foreground="#18181B"/>
                                                        <TextBlock Text="{Binding SessionId}" FontSize="12" FontWeight="Bold" Foreground="#18181B"/>
                                                        <TextBlock Text=" : " FontSize="12" FontWeight="Bold" Foreground="#18181B"/>
                                                        <TextBlock Text="{Binding Username}" FontSize="12" FontWeight="Bold" Foreground="#18181B"/>
                                                        <TextBlock x:Name="TxtCurrentUserCrown" Text=" 👑" FontSize="12" FontWeight="Bold" Foreground="#F59E0B" Visibility="Collapsed"/>
                                                    </StackPanel>
                                                    
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <!-- 物理控制台状态文字，默认隐藏 -->
                                                        <TextBlock x:Name="TxtConsoleStatus" Text="🖥️ 物理控制台" FontSize="11" Foreground="#3B82F6" Margin="0,0,8,0" Visibility="Collapsed"/>
                                                        <!-- 虚拟桌面状态文字，默认显示 -->
                                                        <TextBlock x:Name="TxtVirtualStatus" Text="{Binding StateText}" FontSize="11" Foreground="{DynamicResource BadgeSuccessTextBrush}" Margin="0,0,8,0" Visibility="Visible"/>
                                                        
                                                        <TextBlock Text="运行时间: " FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        <TextBlock Text="{Binding DurationText}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                
                                                <!-- 虚拟会话操作，默认显示 -->
                                                <StackPanel x:Name="PanelVirtualActions" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Visible">
                                                    <Button Content="打开会话" Style="{StaticResource SecondaryBorderButton}" Width="52" Click="BtnOpenSession_Click" Tag="{Binding Username}"/>
                                                    <Button x:Name="BtnDisconnect" Content="保活断开" Style="{StaticResource SecondaryBorderButton}" Width="52" Click="BtnDisconnectSession_Click" Tag="{Binding SessionId}" Margin="4,0,0,0"/>
                                                    <Button Content="彻底退出" Style="{StaticResource DangerBorderButton}" Width="52" Click="BtnLogoffSession_Click" Tag="{Binding SessionId}" Margin="4,0,0,0"/>
                                                </StackPanel>
                                                
                                                <!-- Console 会话操作，默认隐藏 -->
                                                <StackPanel x:Name="PanelConsoleActions" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                                                    <TextBlock Text="系统主桌面" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,4,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        
                                        <DataTemplate.Triggers>
                                            <!-- 当前登录的 Windows 用户账号，在界面上显示皇冠 -->
                                            <DataTrigger Binding="{Binding IsCurrentUser}" Value="True">
                                                <Setter TargetName="TxtCurrentUserCrown" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            
                                            <!-- 当是 Console 会话时，切换可见性 -->
                                            <DataTrigger Binding="{Binding IsConsole}" Value="True">
                                                <Setter TargetName="TxtConsoleStatus" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="TxtVirtualStatus" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="PanelVirtualActions" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="PanelConsoleActions" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            
                                            <!-- 如果是断开状态，调整保活断开按钮是否可用 -->
                                            <DataTrigger Binding="{Binding StateText}" Value="断开">
                                                <Setter TargetName="BtnDisconnect" Property="IsEnabled" Value="False"/>
                                                <Setter TargetName="TxtVirtualStatus" Property="Foreground" Value="#F59E0B"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StateText}" Value="Disconnected">
                                                <Setter TargetName="BtnDisconnect" Property="IsEnabled" Value="False"/>
                                                <Setter TargetName="TxtVirtualStatus" Property="Foreground" Value="#F59E0B"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StateText}" Value="Disc">
                                                <Setter TargetName="BtnDisconnect" Property="IsEnabled" Value="False"/>
                                                <Setter TargetName="TxtVirtualStatus" Property="Foreground" Value="#F59E0B"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Expander>
                </Border>

                <!-- 5. 物理运行日志 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <Expander Style="{StaticResource ModernExpander}" IsExpanded="False">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📝" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="物理运行日志" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextHeadingBrush}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="📤" ToolTip="导出日志" Foreground="{DynamicResource TextHeadingBrush}" Background="Transparent" BorderThickness="0" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="BtnExportLog_Click"/>
                            </Grid>
                        </Expander.Header>
                        <TextBox x:Name="TxtLogOutput" Height="140" Style="{StaticResource ModernTextBox}" 
                                 Background="#18181B" Foreground="{DynamicResource TextMutedBrush}" Margin="0,12,0,0"
                                 VerticalScrollBarVisibility="Auto" AcceptsReturn="True" IsReadOnly="True" 
                                 TextWrapping="Wrap" FontFamily="Consolas, Courier New" FontSize="11"/>
                    </Expander>
                </Border>
                
                <!-- 底部撑开间距 -->
                <Border Height="8"/>
            </StackPanel>
        </ScrollViewer>



        <!-- ======================= 全局新建用户模态框 ======================= -->
        <Grid x:Name="NewUserModal" Grid.RowSpan="2" Background="#80000000" Visibility="Collapsed">
            <Border Width="340" HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Background="#FFFFFF" BorderBrush="#E4E4E7" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="新建本地隔离账户" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="账号名称" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="NewUserUsernameTxt" Height="30" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,0,16">
                        <Grid>
                            <TextBlock Text="连接密码" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <Button x:Name="BtnGeneratePassword" Content="随机强密码" Foreground="#5985E1" Background="Transparent" BorderThickness="0" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" Click="BtnGeneratePassword_Click"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="NewUserPasswordBox" Style="{StaticResource ModernPasswordBox}" Height="30" VerticalContentAlignment="Center" Margin="0" Grid.Column="0" PasswordChanged="NewUserPasswordBox_PasswordChanged"/>
                            <TextBox x:Name="NewUserPasswordTxt" Style="{StaticResource ModernTextBox}" Height="30" VerticalContentAlignment="Center" Margin="0" Grid.Column="0" Visibility="Collapsed" TextChanged="NewUserPasswordTxt_TextChanged"/>
                            <Button x:Name="BtnNewUserShowHidePassword" Grid.Column="2" Content="👁️" Width="30" Height="30" Style="{StaticResource SecondaryBorderButton}" Margin="0" Click="BtnNewUserShowHidePassword_Click"/>
                        </Grid>
                    </StackPanel>
                    
                    <!-- 正在创建时的提示面板 -->
                    <StackPanel x:Name="NewUserLoadingPanel" Visibility="Collapsed" Margin="0,0,0,16">
                        <ProgressBar IsIndeterminate="True" Height="4" Background="{DynamicResource BadgeNeutralBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"/>
                        <TextBlock Text="正在配置组策略和分配隔离权限，请稍候..." FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnCancelNewUser" Content="取消" Style="{StaticResource SecondaryBorderButton}" Height="32" Click="BtnCancelNewUser_Click"/>
                        <Button x:Name="BtnConfirmCreateUser" Content="确认创建" Grid.Column="2" Style="{StaticResource PrimaryBlackButton}" Height="32" Click="BtnConfirmCreateUser_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>