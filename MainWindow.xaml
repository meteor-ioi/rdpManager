<Window x:Class="rdpManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:rdpManager"
        mc:Ignorable="d"
        Title="RDP Manager - RPA 隔离桌面管理器" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#FFFFFF">

    <!-- 局部资源与控制样式定义 (Vercel 风格) -->
    <Window.Resources>
        <!-- 侧边栏按钮样式 -->
        <Style x:Key="SidebarBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="2,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F9F9F9"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 激活状态侧边栏按钮样式 -->
        <Style x:Key="ActiveSidebarBtnStyle" TargetType="Button" BasedOn="{StaticResource SidebarBtnStyle}">
            <Setter Property="Background" Value="#F9F9F9"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="3,0,0,0" BorderBrush="#000000">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vercel 极简黑色按钮样式 -->
        <Style x:Key="VercelBlackButton" TargetType="Button">
            <Setter Property="Background" Value="#000000"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8,16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vercel 边框按钮样式 -->
        <Style x:Key="VercelBorderButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#EAEAEA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="12,6,12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FAFAFA"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#D1D1D1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 输入框样式 -->
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#EAEAEA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6,8,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="#FFFFFF" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 密码框样式 -->
        <Style TargetType="PasswordBox">
            <Setter Property="BorderBrush" Value="#EAEAEA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6,8,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="#FFFFFF" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 左侧导航栏 -->
            <ColumnDefinition Width="240"/>
            <!-- 右侧主体内容 -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ======================= 左侧导航栏 ======================= -->
        <Grid Grid.Column="0" Background="#FFFFFF" BorderBrush="#EAEAEA" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- 软件标题 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock Text="RDP Manager" FontSize="18" FontWeight="Bold" Foreground="#000000" VerticalAlignment="Center"/>
                <Border Background="#FAFAFA" BorderBrush="#EAEAEA" BorderThickness="1" CornerRadius="4" Margin="8,0,0,0" Padding="4,2,4,2">
                    <TextBlock Text="RPA" FontSize="10" FontWeight="Bold" Foreground="#666666"/>
                </Border>
            </StackPanel>

            <!-- 导航菜单 -->
            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                <Button x:Name="NavDashboardBtn" Content="仪表盘" Style="{StaticResource ActiveSidebarBtnStyle}" Click="Nav_Click"/>
                <Button x:Name="NavAccountsBtn" Content="账号管理" Style="{StaticResource SidebarBtnStyle}" Click="Nav_Click" Margin="0,4,0,0"/>
                <Button x:Name="NavSettingsBtn" Content="系统设置" Style="{StaticResource SidebarBtnStyle}" Click="Nav_Click" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 底部服务状态指示 -->
            <Border Grid.Row="2" BorderBrush="#EAEAEA" BorderThickness="0,1,0,0" Padding="20,0,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#0070F3" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusTxt" Text="并发会话已激活(TermWrap)" FontSize="11" Foreground="#666666" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ======================= 右侧主体内容 ======================= -->
        <Grid Grid.Column="1" Background="#FAF9F9">
            
            <!-- 视图 1: 多标签会话容器 (TabControl) -->
            <Grid x:Name="ViewWorkspaces">
                <Grid.RowDefinitions>
                    <!-- 顶部 Tab 栏与操作 -->
                    <RowDefinition Height="48"/>
                    <!-- 主体桌面显示 -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 顶部标签栏 -->
                <Grid Grid.Row="0" Background="#FFFFFF" BorderBrush="#EAEAEA" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tab 页标题区域 -->
                    <TabControl x:Name="WorkspaceTabs" Grid.Column="0" BorderThickness="0" Background="Transparent" 
                                SelectionChanged="WorkspaceTabs_SelectionChanged">
                        <TabControl.Resources>
                            <!-- 隐藏 TabControl 的默认框与多余背景 -->
                            <Style TargetType="TabPanel">
                                <Setter Property="VerticalAlignment" Value="Bottom"/>
                            </Style>
                        </TabControl.Resources>
                    </TabControl>

                    <!-- 右侧 新建连接 按钮 -->
                    <Button Grid.Column="1" Content="+ 新建连接" Style="{StaticResource VercelBlackButton}" 
                            VerticalAlignment="Center" Margin="0,0,16,0" Click="OpenNewConnection_Click"/>
                </Grid>

                <!-- 会话主体显示区 -->
                <Grid Grid.Row="1">
                    <!-- 网格仪表盘视图 (默认选中的 Tab) -->
                    <Grid x:Name="DashboardGridView" Background="#FAF9F9" Margin="32">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="已连接设备" FontSize="20" FontWeight="Bold" Foreground="#000000" Margin="0,0,0,16"/>

                        <!-- 连接卡片网格列表 -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ConnectionCardsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" VerticalAlignment="Top"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#EAEAEA" BorderThickness="1" Background="#FFFFFF" CornerRadius="8" Margin="8" Padding="16">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="180"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- 卡片头部信息 -->
                                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding FriendlyName}" FontSize="15" FontWeight="Bold" Foreground="#000000"/>
                                                        <TextBlock Text="{Binding Server}" FontSize="12" Foreground="#666666" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Border HorizontalAlignment="Right" Background="#FAFAFA" BorderBrush="#EAEAEA" BorderThickness="1" CornerRadius="12" Padding="8,2,8,2">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Ellipse Width="6" Height="6" Fill="{Binding StatusBrush}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#666666" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>

                                                <!-- 远程画面缩略图 -->
                                                <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#EAEAEA" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                                                    <Grid>
                                                        <!-- 若有截图则显示 -->
                                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" />
                                                        <!-- 若无连接或离线状态显示占位 -->
                                                        <TextBlock Text="未建立画面连接" Foreground="#888888" FontSize="13" 
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Visibility="{Binding PlaceholderVisibility}"/>
                                                    </Grid>
                                                </Border>

                                                <!-- 卡片底部操作栏 -->
                                                <Grid Grid.Row="2" Margin="0,12,0,0">
                                                    <Button Content="打开会话标签" Style="{StaticResource VercelBlackButton}" HorizontalAlignment="Left" 
                                                            Tag="{Binding Id}" Click="OpenSessionTab_Click"/>
                                                    <Button Content="断开并保活" Style="{StaticResource VercelBorderButton}" HorizontalAlignment="Right" 
                                                            Tag="{Binding Id}" Click="KeepAliveDisconnect_Click" Visibility="{Binding ActiveActionsVisibility}"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                    
                    <!-- 动态承载打开的 RDP 页面 (通过代码后台动态添加控件) -->
                    <Grid x:Name="ActiveRdpContainer" Visibility="Collapsed" />
                </Grid>
            </Grid>

            <!-- 视图 2: 账号管理面板 -->
            <Grid x:Name="ViewAccounts" Visibility="Collapsed" Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="隔离账户管理" FontSize="20" FontWeight="Bold" Foreground="#000000" Margin="0,0,0,24"/>

                <!-- 快速创建账号卡片 -->
                <Border Grid.Row="1" BorderBrush="#EAEAEA" BorderThickness="1" Background="#FFFFFF" CornerRadius="8" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="快速添加本地机器人账号" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="账号名称" FontSize="12" Foreground="#666666" Margin="0,0,0,6"/>
                                <TextBox x:Name="NewUserTxt" Height="36"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                <TextBlock Text="密码" FontSize="12" Foreground="#666666" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="NewPassTxt" Height="36"/>
                            </StackPanel>

                            <Button Grid.Column="2" Content="+ 一键创建并分配管理员权限" Style="{StaticResource VercelBlackButton}" 
                                    Height="36" VerticalAlignment="Bottom" Click="CreateAccount_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 本地隔离账户列表 -->
                <Border Grid.Row="2" BorderBrush="#EAEAEA" BorderThickness="1" Background="#FFFFFF" CornerRadius="8" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="本地隔离账户列表" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>
                        
                        <DataGrid Grid.Row="1" x:Name="AccountsDataGrid" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" GridLinesVisibility="Horizontal" HeadersVisibility="Column" 
                                  Background="Transparent" BorderThickness="0" RowHeaderWidth="0">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#666666"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#EAEAEA"/>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="账户名" Binding="{Binding Name}" Width="150" IsReadOnly="True"/>
                                <DataGridTextColumn Header="账户类型" Binding="{Binding Type}" Width="150" IsReadOnly="True"/>
                                <DataGridTextColumn Header="密码期限" Binding="{Binding PasswordExpires}" Width="150" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="操作" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="删除账号" Style="{StaticResource VercelBorderButton}" Padding="8,4,8,4" Tag="{Binding Name}" Click="DeleteAccount_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- 视图 3: 系统设置面板 -->
            <Grid x:Name="ViewSettings" Visibility="Collapsed" Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="系统设置" FontSize="20" FontWeight="Bold" Foreground="#000000" Margin="0,0,0,24"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- TermWrap 补丁配置 -->
                        <Border BorderBrush="#EAEAEA" BorderThickness="1" Background="#FFFFFF" CornerRadius="8" Padding="24" Margin="0,0,0,24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="多会话并发环境配置 (TermWrap)" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="当前状态: " Foreground="#666666" FontSize="13"/>
                                        <TextBlock x:Name="TermWrapStatusTxt" Text="检测中..." FontWeight="Bold" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="该功能允许 Windows 系统支持多个本地账户同时连接登录并操作，且系统更新后如果失效，可随时在此页一键检测并修复。" 
                                               Foreground="#888888" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                    <Button x:Name="DeployPatchBtn" Content="激活/修复补丁" Style="{StaticResource VercelBlackButton}" Click="DeployPatch_Click"/>
                                    <Button x:Name="UninstallPatchBtn" Content="卸载补丁" Style="{StaticResource VercelBorderButton}" Margin="12,0,0,0" Click="UninstallPatch_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- RPA 优化策略 -->
                        <Border BorderBrush="#EAEAEA" BorderThickness="1" Background="#FFFFFF" CornerRadius="8" Padding="24" Margin="0,0,0,24">
                            <StackPanel>
                                <TextBlock Text="RPA 运行优化选项 (全局默认设置)" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>
                                <CheckBox x:Name="OptClipboardChk" Content="默认启用双向剪贴板（推荐，方便 RPA 数据交换）" IsChecked="True" Margin="0,0,0,12" FontSize="13"/>
                                <CheckBox x:Name="OptSmartSizingChk" Content="默认启用分辨率自适应（开启后自动缩放桌面）" IsChecked="True" Margin="0,0,0,12" FontSize="13"/>
                                <CheckBox x:Name="OptMuteChk" Content="默认启用静音运行（屏蔽 RDP 会话音频，可极大降低系统资源开销）" IsChecked="True" Margin="0,0,0,12" FontSize="13"/>
                                <CheckBox x:Name="OptUsbChk" Content="默认允许 USB 和 PnP 设备重定向 (UmWrap 摄像头/U盾支持)" IsChecked="False" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <!-- GitHub Actions 构建设置 -->
                        <Border BorderBrush="#EAEAEA" BorderThickness="1" Background="#FFFFFF" CornerRadius="8" Padding="24">
                            <StackPanel>
                                <TextBlock Text="自动构建与更新配置" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>
                                <TextBlock Text="您已配置 GitHub Actions 工作流。当您将代码推送至 GitHub 后，工作流会自动生成 win-x64 的单文件绿色版 EXE。" 
                                           Foreground="#888888" FontSize="12" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="GitHub 仓库推送地址" FontSize="12" Foreground="#666666" Margin="0,0,0,6"/>
                                        <TextBox x:Name="GitRepoTxt" Text="https://github.com/your-username/rdpManager" Height="36"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="构建触发分支" FontSize="12" Foreground="#666666" Margin="0,0,0,6"/>
                                        <TextBox x:Name="GitBranchTxt" Text="main" Height="36"/>
                                    </StackPanel>
                                </Grid>
                                <Button Content="保存构建配置" Style="{StaticResource VercelBlackButton}" HorizontalAlignment="Left" Margin="0,16,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ======================= 全局弹窗层 (新建连接模态框) ======================= -->
        <Grid x:Name="NewConnectionOverlay" Grid.ColumnSpan="2" Background="#80000000" Visibility="Collapsed">
            <Border Width="500" HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Background="#FFFFFF" BorderBrush="#EAEAEA" BorderThickness="1" CornerRadius="8" Padding="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Color="#000000" Opacity="0.12" ShadowDepth="8"/>
                </Border.Effect>
                
                <StackPanel>
                    <!-- 弹窗标题 -->
                    <TextBlock Text="添加新远程桌面" FontSize="18" FontWeight="Bold" Foreground="#000000" Margin="0,0,0,20"/>

                    <!-- 表单字段 -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="电脑名称或本地账户" FontSize="12" Foreground="#666666" Margin="0,0,0,6"/>
                        <!-- 提供快捷选择本地账户，也可手动输入 IP -->
                        <ComboBox x:Name="TargetComputerCombo" Height="36" IsEditable="True"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="密码" FontSize="12" Foreground="#666666" Margin="0,0,0,6"/>
                        <PasswordBox x:Name="TargetPasswordBox" Height="36"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="友好名称 (显示昵称)" FontSize="12" Foreground="#666666" Margin="0,0,0,6"/>
                        <TextBox x:Name="FriendlyNameTxt" Height="36" />
                    </StackPanel>

                    <!-- RPA 特有快捷选项 -->
                    <Border BorderBrush="#EAEAEA" BorderThickness="1" Background="#FAFAFA" CornerRadius="4" Padding="12" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="会话首选项" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <CheckBox x:Name="AutoReconnectChk" Content="如果连接中断，则自动重新连接" IsChecked="True" Margin="0,0,0,6"/>
                            <CheckBox x:Name="RedirectClipboardChk" Content="默认启用双向剪贴板（推荐）" IsChecked="True"/>
                        </StackPanel>
                    </Border>

                    <!-- 弹窗底部操作按钮 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="取消" Style="{StaticResource VercelBorderButton}" Click="CloseNewConnection_Click"/>
                        <Button Content="添加连接" Style="{StaticResource VercelBlackButton}" Margin="12,0,0,0" Click="AddConnectionSubmit_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
