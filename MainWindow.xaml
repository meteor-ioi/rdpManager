<Window x:Class="rdpManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:rdpManager"
        mc:Ignorable="d"
        Title="LocalRDP — 多用户 RPA 隔离管理器" Height="800" Width="980"
        WindowStartupLocation="CenterScreen" Background="#161623"
        Foreground="#EAEAEA">

    <!-- 局部资源与全局控制样式定义 (暗黑磨砂玻璃风格) -->
    <Window.Resources>
        <!-- 磨砂玻璃卡片样式 -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#222538" Opacity="0.85"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <SolidColorBrush Color="#3A3D52" Opacity="0.6"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" Color="#000000" Opacity="0.4" ShadowDepth="3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 玫红强调色按钮样式 -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#E94560"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10,20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF5A75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#555555"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 辅按钮/边框按钮样式 -->
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#4E5166"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="14,8,14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D4055"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#6C708C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#666666"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 暗色风格输入框 -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#171725"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#3A3D52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8,10,8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#EAEAEA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#E94560"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 暗色风格密码框 -->
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#171725"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#3A3D52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8,10,8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#EAEAEA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#E94560"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 自定义下拉框样式 -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#171725"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#3A3D52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6,8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- CheckBox 样式 -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 权限警告横幅 -->
            <RowDefinition Height="Auto"/>
            <!-- 顶部标题 -->
            <RowDefinition Height="64"/>
            <!-- 主体内容 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ======================= 权限警告横幅 ======================= -->
        <Border x:Name="AdminWarningBanner" Grid.Row="0" Background="#E94560" Padding="12,8,12,8" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="⚠" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,8,0"/>
                <TextBlock Text="当前未以管理员身份运行！部分高级保活（如 tscon 会话劫持）和补丁修改操作将无法生效，请使用管理员权限重新运行。" Foreground="#FFFFFF" VerticalAlignment="Center" FontWeight="Medium"/>
            </StackPanel>
        </Border>

        <!-- ======================= 顶部标题 ======================= -->
        <Border Grid.Row="1" Background="#1B1B2F" BorderBrush="#2A2A3D" BorderThickness="0,0,0,1">
            <Grid Margin="20,0,20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="LocalRDP" FontSize="20" FontWeight="Bold" Foreground="#EAEAEA" VerticalAlignment="Center"/>
                    <Border Background="#E94560" CornerRadius="4" Margin="10,0,0,0" Padding="6,2,6,2" VerticalAlignment="Center">
                        <TextBlock Text="RPA 保活版" FontSize="10" FontWeight="Bold" Foreground="#FFFFFF"/>
                    </Border>
                    <TextBlock Text="— 隔离多用户与桌面持久化环境守护" FontSize="13" Foreground="#888CAA" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 系统状态指示器 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#888CAA" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusTxt" Text="并发系统状态查询中..." Foreground="#888CAA" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ======================= 主体内容 ======================= -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="20">
            <StackPanel>

                <!-- 模块 1 — 并发补丁管理 (TermWrap) -->
                <Border Style="{StaticResource GlassCard}">
                    <StackPanel>
                        <!-- Header -->
                        <Grid MouseLeftButtonUp="ToggleModule_Click" Tag="Module1Content" Cursor="Hand" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🛡" FontSize="16" Foreground="#E94560" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="并发补丁管理 (TermWrap)" FontSize="15" FontWeight="Bold" Foreground="#EAEAEA" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Module1Arrow" Grid.Column="2" Text="▽" FontSize="14" Foreground="#888CAA" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Content -->
                        <Border x:Name="Module1Content" Visibility="Collapsed" Margin="0,12,0,0" BorderBrush="#2E3047" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="多路并发组件 (TermWrap) 状态:" Foreground="#888CAA" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TermWrapStatusTxt" Text="查询中..." FontSize="14" FontWeight="SemiBold" Foreground="#EAEAEA"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="提示: 远程并发补丁通过注册表劫持和底层 Hook 技术，解除 Windows 仅支持单会话 RDP 的限制，使得多个 RPA 机器人能够独立、并行登录不同的账号。" Foreground="#888CAA" TextWrapping="Wrap" FontSize="12" Margin="30,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="DeployPatchBtn" Content="安装/修复并发补丁" Style="{StaticResource OutlineButton}" Click="DeployPatch_Click" Margin="0,0,12,0"/>
                                    <Button x:Name="UninstallPatchBtn" Content="还原系统默认配置" Style="{StaticResource OutlineButton}" Click="UninstallPatch_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 模块 2 — 系统账号设置 -->
                <Border Style="{StaticResource GlassCard}">
                    <StackPanel>
                        <!-- Header -->
                        <Grid MouseLeftButtonUp="ToggleModule_Click" Tag="Module2Content" Cursor="Hand" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="👤" FontSize="16" Foreground="#E94560" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="系统隔离账号管理" FontSize="15" FontWeight="Bold" Foreground="#EAEAEA" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Module2Arrow" Grid.Column="2" Text="▲" FontSize="14" Foreground="#888CAA" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Content -->
                        <Border x:Name="Module2Content" Visibility="Visible" Margin="0,12,0,0" BorderBrush="#2E3047" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="5*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 左侧：新建用户 -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="新建隔离账号" FontSize="13" FontWeight="Bold" Foreground="#E94560" Margin="0,0,0,10"/>
                                    <TextBlock Text="账号名称:" Foreground="#888CAA" Margin="0,0,0,4" FontSize="12"/>
                                    <TextBox x:Name="NewUserTxt" Margin="0,0,0,10" Height="34"/>
                                    <TextBlock Text="账号密码:" Foreground="#888CAA" Margin="0,0,0,4" FontSize="12"/>
                                    <PasswordBox x:Name="NewPassTxt" Margin="0,0,0,16" Height="34"/>
                                    <Button x:Name="CreateAccountBtn" Content="新建隔离用户" Style="{StaticResource AccentButton}" Click="CreateAccount_Click" HorizontalAlignment="Left"/>
                                </StackPanel>

                                <!-- 右侧：已有账户选择与凭证填写 -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="选择/编辑登录账户凭证" FontSize="13" FontWeight="Bold" Foreground="#E94560" Margin="0,0,0,10"/>
                                    
                                    <TextBlock Text="选择系统账号 (仅列出非系统内置账号):" Foreground="#888CAA" Margin="0,0,0,4" FontSize="12"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="AccountCombo" Height="34" SelectionChanged="AccountCombo_SelectionChanged"/>
                                        <Button x:Name="DeleteAccountBtn" Grid.Column="1" Content="🗑 删除账号" Style="{StaticResource OutlineButton}" BorderBrush="#E94560" Foreground="#E94560" Click="DeleteAccount_Click" Margin="10,0,0,0"/>
                                    </Grid>

                                    <TextBlock Text="填写凭证密码 (安全保存到 Windows 凭据管理器):" Foreground="#888CAA" Margin="0,0,0,4" FontSize="12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <PasswordBox x:Name="SelectedAccountPasswordTxt" Height="34" PasswordChanged="SelectedAccountPasswordTxt_PasswordChanged"/>
                                        <Button x:Name="SaveCredBtn" Grid.Column="1" Content="💾 保存密码" Style="{StaticResource OutlineButton}" Click="SaveCredBtn_Click" Margin="10,0,0,0" Height="34"/>
                                    </Grid>
                                    <TextBlock Text="* 选中账户后，会自动从凭据管理器填充已保存密码。若在此输入新密码，请点击 [保存密码] 按钮更新。" Foreground="#888CAA" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 模块 3 — 高级保活及重定向 -->
                <Border Style="{StaticResource GlassCard}">
                    <StackPanel>
                        <!-- Header -->
                        <Grid MouseLeftButtonUp="ToggleModule_Click" Tag="Module3Content" Cursor="Hand" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⚙" FontSize="16" Foreground="#E94560" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="高级保活与重定向配置" FontSize="15" FontWeight="Bold" Foreground="#EAEAEA" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Module3Arrow" Grid.Column="2" Text="▲" FontSize="14" Foreground="#888CAA" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Content -->
                        <Border x:Name="Module3Content" Visibility="Visible" Margin="0,12,0,0" BorderBrush="#2E3047" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                            <StackPanel>
                                <!-- 第一行：分辨率与缩放 -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="分辨率选择:" Foreground="#888CAA" Margin="0,0,0,6" FontSize="12"/>
                                        <ComboBox x:Name="ResolutionCombo" SelectedIndex="5">
                                            <ComboBoxItem Content="自适应物理大小" Tag="0x0"/>
                                            <ComboBoxItem Content="800 × 600" Tag="800x600"/>
                                            <ComboBoxItem Content="1024 × 768" Tag="1024x768"/>
                                            <ComboBoxItem Content="1280 × 720" Tag="1280x720"/>
                                            <ComboBoxItem Content="1440 × 900" Tag="1440x900"/>
                                            <ComboBoxItem Content="1920 × 1080" Tag="1920x1080"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="画面缩放比例 (RDP 智能缩放):" Foreground="#888CAA" Margin="0,0,0,6" FontSize="12"/>
                                        <ComboBox x:Name="ScaleCombo" SelectedIndex="0">
                                            <ComboBoxItem Content="100%" Tag="100"/>
                                            <ComboBoxItem Content="125%" Tag="125"/>
                                            <ComboBoxItem Content="150%" Tag="150"/>
                                            <ComboBoxItem Content="175%" Tag="175"/>
                                            <ComboBoxItem Content="200%" Tag="200"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <!-- 第二行：外设重定向 -->
                                <TextBlock Text="外设重定向策略:" Foreground="#888CAA" Margin="0,0,0,8" FontSize="12" FontWeight="Bold"/>
                                <WrapPanel Margin="0,0,0,16">
                                    <CheckBox x:Name="ClipboardChk" Content="同步双向剪贴板" IsChecked="True"/>
                                    <CheckBox x:Name="AudioChk" Content="重定向音频播放" IsChecked="True"/>
                                    <CheckBox x:Name="MicChk" Content="重定向麦克风输入" IsChecked="False"/>
                                    <CheckBox x:Name="DrivesChk" Content="挂载共享本地磁盘" IsChecked="False"/>
                                    <CheckBox x:Name="PrintersChk" Content="共享本地打印机" IsChecked="False"/>
                                    <CheckBox x:Name="SmartSizingChk" Content="启动窗口大小自适应" IsChecked="True"/>
                                </WrapPanel>

                                <!-- 第三行：保活设置 -->
                                <TextBlock Text="远程运行环境保活锁定（核心 RPA 支持）:" Foreground="#E94560" Margin="0,0,0,8" FontSize="12" FontWeight="Bold"/>
                                <StackPanel Margin="0,0,0,20">
                                    <CheckBox x:Name="AutoKeepAliveChk" Content="退出窗口时自动保活会话（不关闭后台运行，自动劫持控制台维持硬件桌面）" IsChecked="True"/>
                                    <CheckBox x:Name="LockResolutionChk" Content="锁定强制恢复物理分辨率（防止控制台锁屏或尺寸畸变导致图像识别失效）" IsChecked="True"/>
                                    <CheckBox x:Name="PreventSleepChk" Content="阻止主机睡眠、系统锁屏与休眠状态（维持屏幕常量）" IsChecked="True"/>
                                </StackPanel>

                                <!-- 连接按钮 -->
                                <Button x:Name="ConnectBtn" Content="🚀 发起隔离 RDP 会话连接" Style="{StaticResource AccentButton}" Click="ConnectBtn_Click" FontSize="14" Height="40" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 模块 4 — 活跃会话管理 -->
                <Border Style="{StaticResource GlassCard}">
                    <StackPanel>
                        <!-- Header -->
                        <Grid MouseLeftButtonUp="ToggleModule_Click" Tag="Module4Content" Cursor="Hand" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📊" FontSize="16" Foreground="#E94560" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="活跃会话实时管理" FontSize="15" FontWeight="Bold" Foreground="#EAEAEA" VerticalAlignment="Center"/>
                            
                            <!-- 数量角标 -->
                            <Border Grid.Column="2" Background="#E94560" CornerRadius="10" MinWidth="20" Height="20" Margin="0,0,15,0" Padding="6,0,6,0" VerticalAlignment="Center">
                                <TextBlock x:Name="SessionCountBadge" Text="0" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="Module4Arrow" Grid.Column="3" Text="▲" FontSize="14" Foreground="#888CAA" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Content -->
                        <Border x:Name="Module4Content" Visibility="Visible" Margin="0,12,0,0" BorderBrush="#2E3047" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                            <StackPanel>
                                <!-- 表头列标题 -->
                                <Border Background="#1D1D2C" Padding="8,6,8,6" CornerRadius="4,4,0,0" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="3*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="用户名" Foreground="#888CAA" FontWeight="Bold" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="会话 ID" Foreground="#888CAA" FontWeight="Bold" FontSize="12"/>
                                        <TextBlock Grid.Column="2" Text="会话状态" Foreground="#888CAA" FontWeight="Bold" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="分辨率" Foreground="#888CAA" FontWeight="Bold" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="运行时长 / 操作" Foreground="#888CAA" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <ListView x:Name="SessionsListView" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Foreground="#EAEAEA">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#2E3047"/>
                                            <Setter Property="Padding" Value="8,10,8,10"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListViewItem">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2A2A3D"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.ItemContainerStyle>

                                    <!-- 右键菜单 -->
                                    <ListView.ContextMenu>
                                        <ContextMenu Background="#222538" Foreground="#EAEAEA">
                                            <MenuItem Header="强制注销 (Logoff)" Click="LogoffSessionContext_Click"/>
                                        </ContextMenu>
                                    </ListView.ContextMenu>

                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <Grid.ColumnDefinition Width="2*"/>
                                                    <Grid.ColumnDefinition Width="1.5*"/>
                                                    <Grid.ColumnDefinition Width="1.5*"/>
                                                    <Grid.ColumnDefinition Width="2*"/>
                                                    <Grid.ColumnDefinition Width="3*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- 用户名 -->
                                                <TextBlock Grid.Column="0" Text="{Binding UserName}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13" Foreground="#FFFFFF"/>
                                                
                                                <!-- 会话 ID -->
                                                <TextBlock Grid.Column="1" Text="{Binding SessionId}" VerticalAlignment="Center" Foreground="#888CAA"/>
                                                
                                                <!-- 状态点与文本 -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Ellipse Width="8" Height="8" Fill="{Binding StateColor}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding StateText}" Foreground="{Binding StateColor}" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- 分辨率 -->
                                                <TextBlock Grid.Column="3" Text="{Binding DisplayResolution}" VerticalAlignment="Center" Foreground="#EAEAEA"/>

                                                <!-- 运行时长与操作按钮 -->
                                                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding RunningTimeText}" Foreground="#888CAA" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                    <Button Content="打开" Style="{StaticResource OutlineButton}" Click="OpenSession_Click" Tag="{Binding}" Height="26" Padding="10,2,10,2" Margin="0,0,8,0" FontSize="11"/>
                                                    <Button Content="断开" Style="{StaticResource OutlineButton}" Click="DisconnectSession_Click" Tag="{Binding SessionId}" Height="26" Padding="10,2,10,2" FontSize="11" BorderBrush="#E94560" Foreground="#E94560"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <TextBlock x:Name="NoSessionsTip" Text="当前暂无活跃的 RPA 用户会话" Foreground="#888CAA" HorizontalAlignment="Center" Margin="0,20,0,20" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ======================= 全局 loading 遮罩 ======================= -->
        <Grid x:Name="GlobalLoadingOverlay" Grid.Row="0" Grid.RowSpan="3" Background="#AA0B0C10" Visibility="Collapsed">
            <Border Background="#222538" BorderBrush="#3A3D52" BorderThickness="1" CornerRadius="10" Padding="30,20,30,20" HorizontalAlignment="Center" VerticalAlignment="Center" Width="380">
                <StackPanel HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Height="4" Background="#1D1D2C" Foreground="#E94560" BorderThickness="0" Margin="0,0,0,15"/>
                    <TextBlock x:Name="LoadingText" Text="正在执行操作，请稍候..." Foreground="#EAEAEA" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>