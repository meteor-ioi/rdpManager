<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Palette (Vercel Inspired) -->
    
    <!-- Surfaces & Borders -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#0A0A0A"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="HeaderBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#333333"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#111111"/>

    <!-- Typography -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EDEDED"/>
    <SolidColorBrush x:Key="TextHeadingBrush" Color="#EDEDED"/>
    <SolidColorBrush x:Key="TextContentBrush" Color="#A1A1AA"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#888888"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#666666"/>

    <!-- Icons -->
    <SolidColorBrush x:Key="IconFillBrush" Color="#888888"/>
    <SolidColorBrush x:Key="IconHoverFillBrush" Color="#EDEDED"/>

    <!-- Primary Button (Vercel Dark: White bg, Black text) -->
    <SolidColorBrush x:Key="PrimaryBtnBackgroundBrush" Color="#EDEDED"/>
    <SolidColorBrush x:Key="PrimaryBtnForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="PrimaryBtnHoverBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryBtnDisabledBgBrush" Color="#333333"/>
    <SolidColorBrush x:Key="PrimaryBtnDisabledTextBrush" Color="#888888"/>

    <!-- Secondary Button (Black bg w/ Border) -->
    <SolidColorBrush x:Key="SecondaryBtnBackgroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SecondaryBtnBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="SecondaryBtnForegroundBrush" Color="#EDEDED"/>
    <SolidColorBrush x:Key="SecondaryBtnHoverBgBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SecondaryBtnHoverBorderBrush" Color="#666666"/>
    <SolidColorBrush x:Key="SecondaryBtnDisabledBgBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SecondaryBtnDisabledTextBrush" Color="#666666"/>

    <!-- Danger Button (Border) -->
    <SolidColorBrush x:Key="DangerBtnForegroundBrush" Color="#F87171"/>
    <SolidColorBrush x:Key="DangerBtnBorderBrush" Color="#7F1D1D"/>
    <SolidColorBrush x:Key="DangerBtnHoverBgBrush" Color="#450A0A"/>
    <SolidColorBrush x:Key="DangerBtnHoverBorderBrush" Color="#EF4444"/>

    <!-- Inputs (TextBox, PasswordBox, ComboBox) -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#EDEDED"/>
    <SolidColorBrush x:Key="InputHoverBorderBrush" Color="#666666"/>
    <SolidColorBrush x:Key="InputDisabledBgBrush" Color="#111111"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="#333333"/>
    <SolidColorBrush x:Key="ScrollbarThumbHoverBrush" Color="#666666"/>
    <SolidColorBrush x:Key="ScrollbarThumbDraggingBrush" Color="#888888"/>

    <!-- Badges -->
    <SolidColorBrush x:Key="BadgeNeutralBgBrush" Color="#333333"/>
    <SolidColorBrush x:Key="BadgeNeutralTextBrush" Color="#EDEDED"/>
    <SolidColorBrush x:Key="BadgeSuccessBgBrush" Color="#064E3B"/>
    <SolidColorBrush x:Key="BadgeSuccessTextBrush" Color="#34D399"/>
    <SolidColorBrush x:Key="BadgeDangerBgBrush" Color="#450A0A"/>
    <SolidColorBrush x:Key="BadgeDangerTextBrush" Color="#F87171"/>
    <SolidColorBrush x:Key="BadgeDisabledBgBrush" Color="#111111"/>
    <SolidColorBrush x:Key="BadgeDisabledTextBrush" Color="#888888"/>

    <!-- Alerts -->
    <SolidColorBrush x:Key="AlertErrorBgBrush" Color="#450A0A"/>
    <SolidColorBrush x:Key="AlertErrorBorderBrush" Color="#7F1D1D"/>
    <SolidColorBrush x:Key="AlertErrorTitleBrush" Color="#FCA5A5"/>
    <SolidColorBrush x:Key="AlertErrorTextBrush" Color="#F87171"/>

    <SolidColorBrush x:Key="AlertWarningBgBrush" Color="#451A03"/>
    <SolidColorBrush x:Key="AlertWarningBorderBrush" Color="#78350F"/>
    <SolidColorBrush x:Key="AlertWarningTitleBrush" Color="#FCD34D"/>
    <SolidColorBrush x:Key="AlertWarningTextBrush" Color="#FBBF24"/>

    <!-- Status Labels -->
    <SolidColorBrush x:Key="StatusSuccessTextBrush" Color="#34D399"/>
    <SolidColorBrush x:Key="StatusErrorTextBrush" Color="#F87171"/>
    <SolidColorBrush x:Key="StatusDisabledTextBrush" Color="#666666"/>

</ResourceDictionary>
